generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
  quotes Quote[]
}

model Quote {
  id          String   @id @default(cuid())
  serviceType String
  description String
  status      String   @default("PENDING")

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Order {
  id          String   @id @default(cuid())
  totalAmount Float
  status      String   @default("PENDING")

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}